APP_NAME=clouddesk-agent
APP_ENV=dev
DEBUG=false
LOG_LEVEL=INFO

# 数据库
DATABASE_URL=postgresql+psycopg2://postgres:123456@localhost:5432/clouddesk
AUTO_CREATE_TABLES=true

# Java 后端配置
JAVA_SERVICE_URL=http://localhost:8101
JAVA_INTERNAL_TOKEN=clouddesk-internal-token

# LLM 配置
OPENAI_API_KEY=
OPENAI_BASE_URL=
LLM_MODEL_FAST=gpt-4o-mini
LLM_MODEL_MEDIUM=gpt-4o
LLM_MODEL_STRONG=gpt-4o

# RAG 配置
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536
RAG_TOP_K=5

# Agent 配置
MAX_HANDOFF_COUNT=2

# 文件上传配置
STORAGE_ROOT=instance/storage
MAX_UPLOAD_SIZE_MB=10
UPLOAD_ALLOWED_EXTENSIONS=jpg,jpeg,png,gif,webp,pdf,txt,csv,xlsx
UPLOAD_SCENE_DIRS=default:uploads,avatar,avatar,document:documents

# 表格数据配置
TABULAR_ALLOWED_EXTENSIONS=csv,xlsx

# PDF 配置
PDF_DEFAULT_FONT=Helvetica